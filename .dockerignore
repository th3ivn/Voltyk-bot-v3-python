# Version control
.git/
.github/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
*.egg

# Virtual environments
.venv/
venv/
env/

# Test and coverage artifacts
tests/
.pytest_cache/
.coverage
coverage.json
htmlcov/

# Linter and type-checker caches
.ruff_cache/
.mypy_cache/

# Local secrets — never include in build context
.env
.env.*
!.env.example

# Editor and OS
.DS_Store
*.swp
*.swo
.idea/
.vscode/

# Development docs
*.md
!README.md
