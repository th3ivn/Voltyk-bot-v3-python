BOT_TOKEN=your_bot_token_here
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/voltyk
REDIS_URL=redis://localhost:6379/0
OWNER_ID=
ADMIN_IDS=
TZ=Europe/Kyiv
WEBHOOK_URL=
WEBHOOK_PATH=/webhook
WEBHOOK_SECRET=
USE_WEBHOOK=false
SUPPORT_CHANNEL_URL=
FAQ_CHANNEL_URL=

# Sentry error monitoring (leave empty to disable)
SENTRY_DSN=
# Set to git commit SHA or version tag so Sentry tracks which deploy introduced a bug.
# On Railway use: SENTRY_RELEASE=$RAILWAY_GIT_COMMIT_SHA
SENTRY_RELEASE=
ENVIRONMENT=production
