# =============================================================================
# Voltyk Bot — приклад змінних середовища
# Скопіюй у .env і заповни реальними значеннями
# =============================================================================

# --- Telegram ---
# Токен бота з @BotFather (обов'язково)
BOT_TOKEN=your_bot_token_here

# Telegram ID власника бота (опціонально)
OWNER_ID=

# Список ID адмін-користувачів через кому, наприклад: 123456789,987654321
ADMIN_IDS=

# --- База даних (Railway PostgreSQL) ---
# Railway автоматично надає DATABASE_URL; бот конвертує postgresql:// → postgresql+asyncpg://
# Формат: postgresql://postgres:PASSWORD@HOST.railway.internal:5432/railway
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/voltyk

# --- Redis ---
# URL Redis-сервера (брокер для Celery та сховище FSM)
REDIS_URL=redis://localhost:6379

# --- Часовий пояс ---
# Використовується Celery Beat і логами
TZ=Europe/Kyiv

# --- Роутер адміна (для моніторингу світла) ---
# IP або хост роутера (опціонально)
ROUTER_HOST=
# Порт роутера (за замовчуванням 80)
ROUTER_PORT=80

# --- Пул з'єднань БД ---
# Мінімальна кількість з'єднань у пулі
DB_POOL_MIN=5
# Максимальна кількість з'єднань у пулі
DB_POOL_MAX=50

# --- Обмеження Telegram API ---
# Максимальна кількість повідомлень на секунду
TELEGRAM_RATE_LIMIT=25
# Кількість повторних спроб надсилання повідомлення
MESSAGE_RETRY_COUNT=3

# --- Celery ---
# Кількість воркерів Celery
CELERY_CONCURRENCY=15

# --- Webhook (не заповнювати для polling-режиму) ---
# Повний URL вебхука, наприклад: https://mybot.example.com/webhook
WEBHOOK_URL=
# Секрет вебхука (рекомендовано для безпеки)
WEBHOOK_SECRET=

# --- Сервер (для webhook-режиму) ---
# Порт, на якому слухає aiohttp сервер
PORT=8000

# --- Логування ---
# Рівень логування: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Режим відлагодження (увімкнути детальні логи SQLAlchemy)
DEBUG=false
