BOT_TOKEN=your_bot_token_here
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/voltyk
REDIS_URL=redis://localhost:6379/0
OWNER_ID=
ADMIN_IDS=
TZ=Europe/Kyiv
WEBHOOK_URL=
WEBHOOK_PATH=/webhook
WEBHOOK_SECRET=
USE_WEBHOOK=false
SUPPORT_CHANNEL_URL=
FAQ_CHANNEL_URL=

# Sentry error monitoring (leave empty to disable)
SENTRY_DSN=
ENVIRONMENT=production

# Schedule data source (fork of outage-data-ua)
DATA_URL_TEMPLATE=https://cdn.jsdelivr.net/gh/th3ivn/outage-data-ua@main/data/{region}.json
IMAGE_URL_TEMPLATE=https://raw.githubusercontent.com/th3ivn/outage-data-ua/main/images/{region}/gpv-{queue}-emergency.png
