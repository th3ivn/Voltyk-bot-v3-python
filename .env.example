BOT_TOKEN=your_bot_token_here
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/voltyk
REDIS_URL=redis://localhost:6379/0
OWNER_ID=
ADMIN_IDS=
TZ=Europe/Kyiv
WEBHOOK_URL=
WEBHOOK_PATH=/webhook
WEBHOOK_SECRET=
USE_WEBHOOK=false
SUPPORT_CHANNEL_URL=
FAQ_CHANNEL_URL=

# ── Observability / access control ─────────────────────────────────────
# These tokens are REQUIRED when ENVIRONMENT=production. Empty tokens disable
# authentication on /health and /metrics, which would leak DB pool stats,
# memory usage, and per-region counters to the public internet.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
HEALTHCHECK_TOKEN=
METRICS_TOKEN=

# Sentry error monitoring (leave empty to disable)
SENTRY_DSN=
# Set to git commit SHA or version tag so Sentry tracks which deploy introduced a bug.
# On Railway use: SENTRY_RELEASE=$RAILWAY_GIT_COMMIT_SHA
SENTRY_RELEASE=
ENVIRONMENT=production

# ── DB connection pool ─────────────────────────────────────────────────
# (DB_POOL_SIZE + DB_MAX_OVERFLOW) × num_replicas must stay below your
# Postgres max_connections, minus ~10 reserved for migrations / psql / admin.
#
# Check your plan: SELECT setting::int FROM pg_settings WHERE name='max_connections';
#
# Defaults (50 + 25 = 75) fit the standard Postgres max_connections=100 with
# a single replica — safe on Railway Hobby, Neon Free, Supabase Free, etc.
# For 150k+ MAU on a larger plan (max_connections ≥ 500) scale up:
#   DB_POOL_SIZE=200, DB_MAX_OVERFLOW=100  (per replica)
DB_POOL_SIZE=50
DB_MAX_OVERFLOW=25
DB_POOL_TIMEOUT_S=30
DB_POOL_RECYCLE_S=1800

# ── Runtime tuning ─────────────────────────────────────────────────────
# Seconds a background task may go without reporting liveness before /health
# flips to 503. Orchestrators (Kubernetes, Railway) should use this to restart
# stuck pods.
BG_TASK_STALE_THRESHOLD_S=300

# In-memory power-monitor state TTL. 48h is enough to avoid re-seeding for
# weekend-inactive users while bounding memory.
USER_STATES_STALE_HOURS=48

# Upper bound on the final dirty-state flush during shutdown. Must be less
# than docker-compose stop_grace_period (30s) to avoid SIGKILL mid-commit.
SHUTDOWN_FLUSH_TIMEOUT_S=15

# Anti-spam cooldown on admin startup/shutdown notifications (seconds).
# Prevents a crashlooping pod from hammering admins on every restart.
ADMIN_NOTIFY_COOLDOWN_S=600
