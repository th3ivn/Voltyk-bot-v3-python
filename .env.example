# === Telegram Bot ===
BOT_TOKEN=your_telegram_bot_token_here
OWNER_ID=your_telegram_user_id_here
ADMIN_IDS=123456789,987654321

# === Database (Neon Postgres) ===
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname

# === Redis (Upstash / Railway) ===
REDIS_URL=redis://localhost:6379/0

# === Webhook ===
WEBHOOK_URL=https://your-app.railway.app
WEBHOOK_PATH=/webhook
WEBHOOK_SECRET=your_random_secret

# === Server ===
PORT=8080

# === Timezone ===
TZ=Europe/Kyiv

# === Celery ===
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_CONCURRENCY=4

# === Scaling ===
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
TELEGRAM_RATE_LIMIT=25

# === Data Sources ===
DATA_URL_TEMPLATE=https://raw.githubusercontent.com/Baskerville42/outage-data-ua/main/data/{region}.json
IMAGE_URL_TEMPLATE=https://raw.githubusercontent.com/Baskerville42/outage-data-ua/main/images/{region}/gpv-{queue}-emergency.png

# === Logging ===
LOG_LEVEL=INFO
