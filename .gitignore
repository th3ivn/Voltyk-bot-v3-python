__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg
.env
.venv/
venv/
env/
*.db
*.sqlite3
.ruff_cache/
.pytest_cache/
.mypy_cache/
htmlcov/
.coverage

# HTTP Archive files — may contain auth tokens, cookies, session IDs, or other
# secrets captured from browser sessions.  Never commit these to the repository.
*.har

# Binary image assets — store in an external CDN, object storage, or Git LFS
# instead of committing them to the source tree.
*.jpg
*.jpeg
*.png
*.gif
*.webp

# Branding assets (exempt from the blanket *.jpg rule)
!assets/channel_photo.jpg
